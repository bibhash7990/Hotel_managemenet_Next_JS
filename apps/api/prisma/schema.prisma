generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  HOTEL_MANAGER
  SUPER_ADMIN
}

enum HotelStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

enum RoomStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  role             UserRole  @default(CUSTOMER)
  name             String
  phone            String?
  avatarUrl        String?
  emailVerified    Boolean   @default(false)
  verifyToken      String?   @unique
  verifyTokenExp   DateTime?
  resetToken       String?   @unique
  resetTokenExp    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  refreshTokens RefreshToken[]
  hotels        Hotel[]        @relation("HotelOwner")
  bookings      Booking[]
  wishlists     Wishlist[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Hotel {
  id          String      @id @default(cuid())
  ownerId     String
  owner       User        @relation("HotelOwner", fields: [ownerId], references: [id])
  name        String
  slug        String      @unique
  description String
  address     String
  city        String
  country     String
  lat         Float?
  lng         Float?
  starRating  Int
  amenities   Json        @default("[]")
  images      Json        @default("[]")
  status      HotelStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  rooms    Room[]
  bookings Booking[]
  wishlist Wishlist[]

  @@index([city, country, status])
}

model Room {
  id             String     @id @default(cuid())
  hotelId        String
  hotel          Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name           String
  type           String
  description    String?
  pricePerNight  Decimal    @db.Decimal(12, 2)
  capacity       Int
  beds           Int
  amenities      Json       @default("[]")
  images         Json       @default("[]")
  totalQuantity  Int
  status         RoomStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  bookings Booking[]

  @@index([hotelId])
}

model Booking {
  id                        String        @id @default(cuid())
  userId                    String
  user                      User          @relation(fields: [userId], references: [id])
  hotelId                   String
  hotel                     Hotel         @relation(fields: [hotelId], references: [id])
  roomId                    String
  room                      Room          @relation(fields: [roomId], references: [id])
  checkIn                   DateTime
  checkOut                  DateTime
  guests                    Int
  totalPrice                Decimal       @db.Decimal(12, 2)
  status                    BookingStatus @default(PENDING)
  stripePaymentIntentId     String?       @unique
  stripeCheckoutSessionId   String?       @unique
  specialRequests           String?
  guestName                 String?
  guestEmail                String?
  guestPhone                String?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  payment Payment?

  @@index([roomId, checkIn, checkOut])
  @@index([userId, status])
  @@index([status, createdAt])
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique
  booking               Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String        @unique
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  refundId              String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, hotelId])
  @@index([userId])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
